19. Распакуйте архивы etc_backup, упакованные gzip и 7zip в каталоги /root/etc_backup_gzip и /root/etc_backup_7zip, сравните программой diff файлы motd в этих каталогах.

root@eltex-practice2-v40:~# mkdir etc_backup_gzip
root@eltex-practice2-v40:~# tar -xzf etc_backup.tar.gz -C /root/etc_backup_gzip

root@eltex-practice2-v40:~# 7z x /root/etc_backup.tar.7z -o/root/etc_backup_7zip
root@eltex-practice2-v40:~/etc_backup_7zip# tar -xf etc_backup.tar

root@eltex-practice2-v40:~# diff -u etc_backup_gzip/etc_backup/motd etc_backup_7zip/etc_backup/motd 
